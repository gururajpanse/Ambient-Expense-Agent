# =============================================================================
# Ambient Expense Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Authentication (choose one) ---

# Option 1: Google AI Studio (recommended for local development)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your-api-key-here

# Option 2: Vertex AI (for GCP deployments)
# Run `gcloud auth application-default login` to set up ADC locally.
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_GENAI_USE_VERTEXAI=True

# --- Optional: Observability ---

# GCS bucket for telemetry/prompt logging (metadata-only mode)
# LOGS_BUCKET_NAME=gs://your-telemetry-bucket

# Enable prompt/response capture (set to NO_CONTENT for metadata only)
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT
